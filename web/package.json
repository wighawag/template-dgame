{
	"name": "reveal-or-die-web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"dependencies": {
		"@etherplay/connect": "^0.0.34",
		"@lucide/svelte": "^0.544.0",
		"@pixi/devtools": "^2.0.1",
		"abitype": "^1.1.1",
		"bits-ui": "^2.11.4",
		"reveal-or-die-contracts": "workspace:*",
		"clsx": "^2.1.1",
		"driver.js": "^1.3.6",
		"eip-1193": "^0.6.5",
		"gsap": "^3.13.0",
		"named-logs": "^0.4.1",
		"pixi-viewport": "^6.0.3",
		"pixi.js": "^8.13.2",
		"pretty-ms": "^9.3.0",
		"tseep": "^1.3.1",
		"tw-animate-css": "^1.4.0",
		"viem": "^2.37.8"
	},
	"devDependencies": {
		"@assetpack/core": "^1.7.0",
		"@sveltejs/adapter-static": "^3.0.9",
		"@sveltejs/kit": "^2.43.5",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/forms": "^0.5.10",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.13",
		"@vitejs/plugin-basic-ssl": "^2.1.0",
		"ipfs-gateway-emulator": "4.2.1-ipfs.2",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.6.14",
		"pwag": "^0.4.0",
		"svelte": "^5.39.6",
		"svelte-check": "^4.3.2",
		"tailwindcss": "^4.1.13",
		"typescript": "^5.9.2",
		"vite": "^7.1.7",
		"vite-plugin-devtools-json": "^1.0.0"
	},
	"scripts": {
		"prepare": "pnpm generate-pwa-icons-and-tags && svelte-kit sync",
		"generate-pwa-icons-and-tags": "pwag static/icon.png src/web-config.json --html src/app.template.html --html-output src/app.html --assets-prefix %sveltekit.assets%",
		"dev": "ldenv vite dev",
		"build": "ldenv vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"serve": "ipfs-emulator --only -d build -p 8080"
	}
}